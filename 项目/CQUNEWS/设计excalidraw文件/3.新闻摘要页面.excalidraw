    {
      "id": "9sINjiSXaY5u30E-ByXgv",
      "type": "text",
      "x": 1532.5,
      "y": 1035.375,
      "width": 614.47998046875,
      "height": 480,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
