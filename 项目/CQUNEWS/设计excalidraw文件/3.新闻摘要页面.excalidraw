    {
      "id": "hJa37vXG2m-aCA3OfVIyN",
      "type": "text",
      "x": 480,
      "y": 296.625,
      "width": 811.6159057617188,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
